@page "/admin/catalogue/bouquets"
@attribute [Authorize]
@using System.Globalization
@using FloristShop.Web.Modules.Admin.Services
@using FloristShop.Web.Modules.Dictionary.Services
@using FloristShop.Web.Modules.Shop.Models
@inject AdminBouquetCatalogService CatalogSvc
@inject DictionaryService DictSvc

<PageTitle>Bouquet Catalogue - Admin</PageTitle>

<div class="container py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="admin" class="btn btn-outline-secondary btn-sm">← Admin Panel</a>
        <h1 class="h4 mb-0">Bouquet Catalogue</h1>
        <a href="admin/catalogue/bouquets/new" class="btn btn-primary btn-sm ms-auto">
            + Add bukiet
        </a>
    </div>

    @if (_templates.Count == 0)
    {
        <div class="alert alert-info">No templates bukietów. <a href="admin/catalogue/bouquets/new">Add pierwszy</a>.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:80px">Zdjęcie</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price bazowa</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in _templates)
                    {
                        <tr class="@(t.IsActive ? "" : "opacity-50")">
                            <td>
                                @if (t.ImagePaths.Count > 0)
                                {
                                    <img src="@t.ImagePaths[0]" alt="@t.Name"
                                         style="width:60px;height:60px;object-fit:cover;border-radius:6px;" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center bg-light rounded"
                                         style="width:60px;height:60px;font-size:1.5rem;">
                                        @CategoryEmoji(t.Category)
                                    </div>
                                }
                            </td>
                            <td>
                                <div class="fw-semibold">@t.Name</div>
                                @if (!string.IsNullOrWhiteSpace(t.Description))
                                {
                                    <div class="text-muted small" style="max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @t.Description
                                    </div>
                                }
                            </td>
                            <td class="text-muted small">@CategoryLabel(t.Category)</td>
                            <td class="fw-semibold">@t.BasePrice.ToString("C", GbCulture)</td>
                            <td>
                                @if (t.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Ukryty</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="admin/catalogue/bouquets/@t.Id" class="btn btn-outline-primary btn-sm">
                                        Edit
                                    </a>
                                    <form method="post" style="display:inline">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="Delete.ItemId" value="@t.Id" />
                                        <button type="submit"
                                                class="btn btn-delete btn-sm"
                                                onclick="return confirm('Na pewno usunac ten bukiet?')">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private static readonly CultureInfo GbCulture = CultureInfo.GetCultureInfo("en-GB");
    private List<BouquetTemplate> _templates = [];
    private Dictionary<string, string> _labelMap = [];

    [SupplyParameterFromForm]
    private DeleteForm Delete { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        if (Delete.ItemId.HasValue)
            await CatalogSvc.DeleteAsync(Delete.ItemId.Value);

        _templates = await CatalogSvc.GetAllAsync();
        _labelMap = await DictSvc.GetLabelMapAsync(DictionaryService.Types.BouquetCategory);
    }

    private string CategoryLabel(string key) =>
        _labelMap.TryGetValue(key, out var label) ? label : key;

    private static string CategoryEmoji(string c) => c switch
    {
        "Wedding"     => "💍",
        "Anniversary" => "🥂",
        "Birthday"    => "🎂",
        "Sympathy"    => "🕊️",
        "Romantic"    => "❤️",
        "Everyday"    => "🌻",
        _             => "💐"
    };

    public class DeleteForm
    {
        public Guid? ItemId { get; set; }
    }
}
