@page "/admin"
@attribute [Authorize]

@*
    Admin panel home — hub with tiles to each module.
    [Authorize] without parameters = requires ANY logged-in user.
    We have one permission level (Admin), so this is sufficient.

    No @rendermode = pure SSR. Dashboard needs no interactivity.
*@

<PageTitle>Admin Panel - Petal &amp; Bloom</PageTitle>

<div class="container py-4">
    <h1 class="h3 mb-1">Admin Panel</h1>
    <p class="text-muted mb-4">Welcome, @_userName. What would you like to manage today?</p>

    <div class="row g-4">

        <div class="col-md-4">
            <a href="admin/reservations" class="text-decoration-none">
                <div class="card h-100 border-primary">
                    <div class="card-body">
                        <div class="display-6 mb-2">📦</div>
                        <h5 class="card-title text-primary">Rental Reservations</h5>
                        <p class="card-text text-muted small">
                            All prop hire enquiries. Update status, add a note, confirm the date.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/orders" class="text-decoration-none">
                <div class="card h-100 border-primary">
                    <div class="card-body">
                        <div class="display-6 mb-2">🛍️</div>
                        <h5 class="card-title text-primary">Orders (bouquets)</h5>
                        <p class="card-text text-muted small">
                            Orders from the online shop. Update status, mark as paid, add a note.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/decorations" class="text-decoration-none">
                <div class="card h-100 border-primary">
                    <div class="card-body">
                        <div class="display-6 mb-2">💐</div>
                        <h5 class="card-title text-primary">Decoration Enquiries</h5>
                        <p class="card-text text-muted small">
                            Enquiries for wedding and event decorations. Update status, set price, add a note.
                        </p>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <h2 class="h5 text-muted border-bottom pb-2 mt-5 mb-4">Catalogues &amp; Gallery</h2>

    <div class="row g-4">

        <div class="col-md-4">
            <a href="admin/catalogue/bouquets" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <div class="display-6 mb-2">🌹</div>
                        <h5 class="card-title text-secondary">Bouquet Catalogue</h5>
                        <p class="card-text text-muted small">
                            Add, edit, and hide bouquet templates. Upload photos, set prices.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/catalogue/rental" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <div class="display-6 mb-2">🏺</div>
                        <h5 class="card-title text-secondary">Prop Catalogue</h5>
                        <p class="card-text text-muted small">
                            Add, edit, and hide hire props. Upload photos, set quantities.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/gallery" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <div class="display-6 mb-2">📸</div>
                        <h5 class="card-title text-secondary">Gallery</h5>
                        <p class="card-text text-muted small">
                            Upload photos from events and arrangements. Visible on the /gallery page.
                        </p>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <h2 class="h5 text-muted border-bottom pb-2 mt-5 mb-4">Dictionaries</h2>

    <div class="row g-4">

        <div class="col-md-4">
            <a href="admin/dictionaries/rental_category" class="text-decoration-none">
                <div class="card h-100 border-light">
                    <div class="card-body">
                        <div class="display-6 mb-2">🗂️</div>
                        <h5 class="card-title text-body">Prop Categories</h5>
                        <p class="card-text text-muted small">
                            Add and edit categories used in the hire catalogue.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/dictionaries/bouquet_category" class="text-decoration-none">
                <div class="card h-100 border-light">
                    <div class="card-body">
                        <div class="display-6 mb-2">🗂️</div>
                        <h5 class="card-title text-body">Bouquet Categories</h5>
                        <p class="card-text text-muted small">
                            Add and edit categories used in the bouquet shop.
                        </p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a href="admin/dictionaries/gallery_category" class="text-decoration-none">
                <div class="card h-100 border-light">
                    <div class="card-body">
                        <div class="display-6 mb-2">🗂️</div>
                        <h5 class="card-title text-body">Gallery Categories</h5>
                        <p class="card-text text-muted small">
                            Add and edit photo categories in the gallery.
                        </p>
                    </div>
                </div>
            </a>
        </div>

    </div>

</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private string _userName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateTask;
        _userName = auth.User.Identity?.Name ?? "Admin";
    }
}
