@page "/decorations/inquiry/confirmation/{InquiryNumber}"

<PageTitle>Enquiry Received - Petal &amp; Bloom</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card border-success">
                <div class="card-body text-center py-5">

                    <div class="display-1 text-success mb-3" aria-hidden="true">✓</div>

                    <h1 class="h3 mb-2">Enquiry received!</h1>

                    <p class="text-muted mb-4">
                        Your decoration enquiry has been registered.
                        We will be in touch within 24&nbsp;hours.
                    </p>

                    <div class="bg-light rounded p-3 mb-4">
                        <p class="small text-muted mb-1">Your enquiry number:</p>
                        <p class="fs-4 fw-bold font-monospace mb-0 text-primary">
                            @InquiryNumber
                        </p>
                    </div>

                    <p class="small text-muted mb-4">
                        Save this number — you can quote it by phone or email so we can
                        find your enquiry quickly.
                    </p>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <a href="decorations" class="btn btn-outline-secondary">
                            Back to decorations
                        </a>
                        <a href="/" class="btn btn-outline-secondary">
                            Home
                        </a>
                    </div>

                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded small">
                <p class="fw-semibold mb-2">What happens next?</p>
                <ol class="mb-0 ps-3">
                    <li class="mb-1">We will call or email to discuss your event in detail.</li>
                    <li class="mb-1">We will prepare a bespoke quote and send it for your approval.</li>
                    <li>Once approved, we agree a date and get to work.</li>
                </ol>
            </div>

        </div>
    </div>
</div>

@code {
    [Parameter]
    public string InquiryNumber { get; set; } = string.Empty;
}
