<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital@0;1&family=Cormorant+Garamond:ital,wght@0,300;1,300&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/css/glightbox.min.css" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["FloristShop.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="floristshop_logo_circle.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="@Assets["favicon.png"]" />
    <link rel="apple-touch-icon" sizes="180x180" href="@Assets["apple-touch-icon.png"]" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/glightbox/3.3.0/js/glightbox.min.js"></script>
    <script src="js/crop-helpers.js"></script>
    <script>
        // GLightbox — reinitialise after navigation and after streaming SSR (MutationObserver)
        let _glightbox = null;
        let _glightboxTimer = null;
        let _glightboxOpen = false;

        function initGLightbox() {
            if (typeof GLightbox === 'undefined') return;
            if (_glightboxOpen) return; // don't destroy when lightbox is open
            if (_glightbox) { _glightbox.destroy(); _glightbox = null; }
            if (document.querySelector('.glightbox')) {
                _glightbox = GLightbox({ selector: '.glightbox', touchNavigation: true, loop: true });
                _glightbox.on('open', () => { _glightboxOpen = true; });
                _glightbox.on('close', () => { _glightboxOpen = false; });
            }
        }

        // Debounce — wait 80ms after last DOM change before initialising
        function scheduleGLightbox() {
            clearTimeout(_glightboxTimer);
            _glightboxTimer = setTimeout(initGLightbox, 80);
        }

        document.addEventListener('DOMContentLoaded', () => {
            scheduleGLightbox();
            new MutationObserver(scheduleGLightbox)
                .observe(document.body, { childList: true, subtree: true });
        });

        document.addEventListener('blazor:navigated', scheduleGLightbox);
    </script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
