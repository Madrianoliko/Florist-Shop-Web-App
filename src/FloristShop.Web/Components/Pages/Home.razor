@* ═══════════════════════════════════════════════════════════
   FOOTER
   ═══════════════════════════════════════════════════════════ *@
<footer class="kw-footer">
    <div class="container">
        <div class="kw-footer-inner">
            <span class="kw-script" style="font-size:1.3rem; color:#C4A0A6;">Petal &amp; Bloom</span>
            <div class="kw-footer-links">
                <a href="/shop">Shop</a>
                <a href="/rental">Rental</a>
                <a href="/decorations">Decorations</a>
                <a href="/gallery">Gallery</a>
            </div>
