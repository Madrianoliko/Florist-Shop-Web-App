@page "/"
@*
    Home page — one-page landing.
    Pure SSR: no @rendermode required, no interactivity.

    Sections:
    1. Hero          — background image + headline
    2. Why us        — 4 icons with values
    3. Offer         — 3 cards (Bouquets, Decorations, Rental)
    4. About us      — Sophie and James, photos + text
    5. Reviews       — 3 featured Google reviews
    6. Contact       — address, phone, hours + map
*@

<PageTitle>Petal &amp; Bloom — Florist &amp; Event Decorations, Bristol</PageTitle>
<HeadContent>
    <meta name="description" content="Petal &amp; Bloom — florist and event decorations in Bristol, UK. Bouquets for every occasion, wedding and event decorations, prop hire. Tel. +44 117 496 0320." />
</HeadContent>

@* ═══════════════════════════════════════════════════════════
   SECTION 1 — HERO
   ═══════════════════════════════════════════════════════════ *@
<section class="kw-hero">
    <div class="kw-hero-box">
        <div class="kw-hero-box-content">
            <p class="kw-label mb-3">Florist · Event Decorations</p>
            <h1 class="kw-hero-title">
                Flowers crafted<br>
                <em>with heart</em>
            </h1>
            <p class="kw-hero-text">
                Bespoke bouquets, wedding and event decorations,
                prop hire. Every arrangement is made by hand —
                with care for every detail.
            </p>
            <div class="kw-hero-cta">
                <a href="/shop" class="kw-btn-white">Browse the shop</a>
                <a href="#contact" class="kw-btn-outline-white">Contact us</a>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   SECTION 2 — WHY US
   ═══════════════════════════════════════════════════════════ *@
<section class="kw-section kw-section-cream">
    <div class="container">
        <div class="kw-section-header">
            <p class="kw-label">Why choose us</p>
            <h2 class="kw-script" style="font-size:2.2rem; color:var(--kw-warm-dark);">A passion for flowers</h2>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-6 col-md-3 text-center">
                <div class="kw-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/></svg>
                </div>
                <h5 class="kw-feature-title">Made with love</h5>
                <p class="kw-feature-text">Every bouquet is created individually, with care for each stem and ribbon.</p>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="kw-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
                </div>
                <h5 class="kw-feature-title">Family run</h5>
                <p class="kw-feature-text">Run by Sophie and James — we know our flowers and we know our customers.</p>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="kw-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <h5 class="kw-feature-title">5-star rated</h5>
                <p class="kw-feature-text">Rated 5.0 on Google based on reviews from our happy customers.</p>
            </div>
            <div class="col-6 col-md-3 text-center">
                <div class="kw-feature-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <h5 class="kw-feature-title">Quick turnaround</h5>
                <p class="kw-feature-text">We can often prepare a bouquet same day — call us and ask.</p>
            </div>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   SECTION 3 — OFFER
   ═══════════════════════════════════════════════════════════ *@
<section class="kw-section">
    <div class="container">
        <div class="kw-section-header">
            <p class="kw-label">What we offer</p>
            <h2 class="kw-script" style="font-size:2.2rem; color:var(--kw-warm-dark);">Our services</h2>
        </div>
        <div class="row g-4">

            <div class="col-md-4">
                <div class="kw-offer-card">
                    <div class="kw-offer-photo" style="background-image:url('/images/flowers.jpg');">
                        <span class="kw-offer-label">Online shop</span>
                    </div>
                    <div class="kw-offer-body">
                        <h3 class="kw-offer-title">Bouquets</h3>
                        <p class="kw-offer-text">
                            Arrangements for every occasion — weddings, birthdays, thank-yous,
                            and condolences. Order online and collect in store.
                        </p>
                        <a href="/shop" class="kw-offer-link">
                            Browse the catalogue
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kw-offer-card">
                    <div class="kw-offer-photo" style="background-image:url('/images/decorations.jpg');">
                        <span class="kw-offer-label">Bespoke</span>
                    </div>
                    <div class="kw-offer-body">
                        <h3 class="kw-offer-title">Decorations</h3>
                        <p class="kw-offer-text">
                            Wedding, celebration, and event styling. Church, reception venue,
                            balloon walls, floral arches — all designed with imagination.
                        </p>
                        <a href="/decorations" class="kw-offer-link">
                            Send an enquiry
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kw-offer-card">
                    <div class="kw-offer-photo" style="background-image:url('/images/things.jpg');">
                        <span class="kw-offer-label">Hire</span>
                    </div>
                    <div class="kw-offer-body">
                        <h3 class="kw-offer-title">Prop Hire</h3>
                        <p class="kw-offer-text">
                            Vases, candlesticks, floral arches, lanterns, stands —
                            props for weddings and celebrations.
                        </p>
                        <a href="/rental" class="kw-offer-link">
                            Browse props
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   SECTION 4 — ABOUT US
   ═══════════════════════════════════════════════════════════ *@
<section class="kw-section kw-section-cream" id="about">
    <div class="container">
        <div class="row g-5 align-items-center">

            @* Photos *@
            <div class="col-md-5">
                <div class="kw-about-photos">
                    <img src="/images/women.jpg"
                         alt="Sophie — owner"
                         class="kw-about-photo-main" />
                    <img src="/images/man.jpg"
                         alt="James with a bouquet"
                         class="kw-about-photo-accent" />
                </div>
            </div>

            @* Text *@
            <div class="col-md-7">
                <p class="kw-label mb-2">Meet us</p>
                <h2 class="kw-script mb-4" style="font-size:2.2rem; color:var(--kw-warm-dark);">
                    Sophie and James
                </h2>
                <p class="kw-about-text">
                    We are a family-run florist in Bristol, driven by a genuine passion for flowers.
                    Sophie designs and creates all the bouquets and decorations — every arrangement is
                    composed with imagination and attention to detail. James handles the logistics
                    and is always on hand to deliver flowers with a smile.
                </p>
                <p class="kw-about-text">
                    Together we have created a place where every customer is treated as an individual.
                    We specialise in wedding and event decorations, but take equal delight in putting
                    together a birthday bouquet, an anniversary arrangement, or simply flowers for no
                    particular reason at all.
                </p>
                <div class="kw-about-rating mt-4">
                    <span class="kw-stars">★★★★★</span>
                    <span class="kw-about-rating-text">5.0 · Reviews on Google</span>
                </div>
            </div>

        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   SECTION 5 — REVIEWS
   ═══════════════════════════════════════════════════════════ *@
<section class="kw-section">
    <div class="container">
        <div class="kw-section-header">
            <p class="kw-label">What our customers say</p>
            <h2 class="kw-script" style="font-size:2.2rem; color:var(--kw-warm-dark);">Google Reviews</h2>
        </div>
        <div class="row g-4">

            <div class="col-md-4">
                <div class="kw-review-card">
                    <div class="kw-review-header">
                        <div class="kw-review-avatar" style="background:#C4A0A6;">EH</div>
                        <div>
                            <p class="kw-review-name">Emily H</p>
                            <span class="kw-stars-sm">★★★★★</span>
                        </div>
                    </div>
                    <p class="kw-review-text">
                        "Absolutely stunning balloon wall for my daughter's 18th birthday.
                        Sophie created something truly magical — everyone was in awe.
                        Wonderful service from start to finish."
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kw-review-card">
                    <div class="kw-review-header">
                        <div class="kw-review-avatar" style="background:#8FAD82;">AW</div>
                        <div>
                            <p class="kw-review-name">Anna W</p>
                            <span class="kw-stars-sm">★★★★★</span>
                        </div>
                    </div>
                    <p class="kw-review-text">
                        "Highly recommend the wedding decorations by Sophie!
                        Both the church and the reception venue looked breathtaking —
                        every single detail was perfect."
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="kw-review-card">
                    <div class="kw-review-header">
                        <div class="kw-review-avatar" style="background:#B0A88A;">SJ</div>
                        <div>
                            <p class="kw-review-name">Sarah J</p>
                            <span class="kw-stars-sm">★★★★★</span>
                        </div>
                    </div>
                    <p class="kw-review-text">
                        "We wholeheartedly recommend Petal &amp; Bloom for wedding and event
                        decorations. Sophie is a pleasure to work with —
                        attentive, creative, and thoroughly professional."
                    </p>
                </div>
            </div>

        </div>
        <div class="text-center mt-4">
            <a href="https://www.google.com/maps/place/Petal+and+Bloom+Florist+Bristol"
               target="_blank" rel="noopener" class="kw-more-reviews">
                See all reviews on Google →
            </a>
        </div>
    </div>
</section>

@* ═══════════════════════════════════════════════════════════
   SECTION 6 — CONTACT
